# ── Dependencias (Docker ejecuta npm install en la imagen) ───────────────
node_modules/

# ── Salida de Next.js / builds locales ────────────────────────────────────
.next/
out/
dist/
build/

# ── Variables de entorno locales (Docker usa env en docker-compose) ──────
.env
.env.*
!.env.example

# ── Logs y depuración ──────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── Cachés y herramientas ────────────────────────────────────────────────
.turbo/
.swc/
.cache/
*.tsbuildinfo
.eslintcache

# ── Pruebas / cobertura ────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Editores e IDE (no afectan el contenedor) ─────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Sistema operativo ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Despliegues locales (p. ej. Vercel CLI) ───────────────────────────────
.vercel/

# ── Volúmenes / datos locales de Postgres si montaras fuera de Docker ──────
# (ajusta si usas dumps o backups en la raíz del repo)
*.sql~
postgres_data/
